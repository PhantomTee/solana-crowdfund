# ── ElevenLabs TTS (for voice pitch on campaign creation) ────────────────────
# Free tier works. Get your key at: https://elevenlabs.io
ELEVENLABS_API_KEY=sk_...
# Optional: defaults to Rachel (free voice). Find voice IDs in ElevenLabs dashboard.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── LLM Reasoning — set ONE of these ─────────────────────────────────────────
# OpenRouter (preferred — free Mistral model available):
#   https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-...

# Heurist (alternative):
#   https://dev.heurist.ai
HEURIST_API_KEY=heu_...

# ── Virtuals Terminal API (activity logging for the AI agent) ─────────────────
# Get an agent API key at: https://app.virtuals.io
# The key starts with "apt-"
VIRTUALS_API_KEY=apt-...
# ECDSA P-256 private key in PKCS#8 DER base64 format (generated alongside your agent)
VIRTUALS_SIGNER_PRIVATE_KEY=MIGHAgEAMBMGByqGSM49...

# ── Agent Solana Wallet ───────────────────────────────────────────────────────
# Base58 public key of the agent's donation wallet.
# Generate a new keypair: https://solfaucet.com or `solana-keygen new`
# Fund with SOL:  https://faucet.solana.com (devnet)
# Fund with USDC: https://faucet.circle.com (devnet)
AGENT_SOLANA_PUBLIC_KEY=...
# Base64-encoded 64-byte secret key
AGENT_SOLANA_SECRET_KEY=...
